<%- include('includes/head') %>
<%- include('includes/nav') %>

  <div class="conteiner">
    <div class="row">
      <div class="col-lg-2"></div>

      <div class="col-lg-8 my-5">
        <h1 class="display- text-center">Agenda</h1>
        <P class="text-center lead">Sua agenda de contatos</P>

        <%- include('includes/messages.ejs')%>  

        <%if (contatos.length > 0) {%>
          <div class="responsive-table">
            <table class="table my-3">
              <%contatos.forEach(contato => {%>
                <tr>
                <td><%=contato.nome%></td>
                <td><%=contato.sobrenome%></td>
                <td><%=contato.telefone%></td>
                <td><%=contato.email%></td>
                <td><a href="/contato/index/<%= contato._id %>">Editar</a></td>
                <td><a class="text-danger" href="/contato/delete/<%= contato._id %>">Excluir</a></td>
                </tr>
             <%});%>
        <%} else {%>
          <p class="text-center lead">Não tem contatos na sua agenda</p>
        <%}%>
            
          </table>
        </div>
      
      <div class="col-lg-2"></div>
    </div>
  </div>

<%- include('includes/footer') %>
  